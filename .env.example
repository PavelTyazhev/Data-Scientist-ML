# GIGACHAT_TOKEN: Token for Sberbank GigaChat API integration (OAuth Client Secret).
# If not specified, the system will use a working default token for convenience.
GIGACHAT_TOKEN="ВАШ_КЛИЕНТСКИЙ_СЕКРЕТ_GIGACHAT"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
APP_URL="http://localhost:3000"
